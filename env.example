# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ankiety
POSTGRES_USER=ankiety_user
POSTGRES_PASSWORD=ankiety_secret_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=ankiety-super-secret-jwt-key-change-in-production

# Survey API
SURVEY_API_PORT=3000

# Voting Service
VOTING_SERVICE_PORT=3001

# WebSocket Server
WEBSOCKET_PORT=3002

# Vote Worker
WORKER_BATCH_SIZE=100
WORKER_INTERVAL_MS=5000
